# Supabase — Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret   # Settings > API > JWT Secret (HS256)

# External APIs
OPENAI_API_KEY=sk-...

# Open model chat for /reflect through Hugging Face Inference Providers
OPEN_MODEL_API_KEY=hf_...
OPEN_MODEL_BASE_URL=https://router.huggingface.co/v1
OPEN_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-1M:fastest
OPEN_MODEL_MAX_TOKENS=350
OPEN_MODEL_TEMPERATURE=0.7
OPEN_MODEL_INCLUDE_TRANSCRIPT=false

# Keyless open-model fallback for /reflect (Pollinations openai-fast / GPT-OSS 20B).
# Set false in production if you only want token-backed providers.
OPEN_MODEL_ALLOW_ANONYMOUS=true
ANONYMOUS_OPEN_MODEL_BASE_URL=https://text.pollinations.ai
ANONYMOUS_OPEN_MODEL_NAME=openai-fast
ANONYMOUS_OPEN_MODEL_API_KEY=

# Optional legacy provider for debrief generation
ANTHROPIC_API_KEY=sk-ant-...

# Stripe billing for Mirra Pro
# STRIPE_PRO_PRICE_ID should point at the $8/month recurring Price in Stripe.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TRIAL_DAYS=14
STRIPE_SUCCESS_URL=http://127.0.0.1:8081/profile?checkout=success
STRIPE_CANCEL_URL=http://127.0.0.1:8081/profile?checkout=cancelled
STRIPE_PORTAL_RETURN_URL=http://127.0.0.1:8081/profile

# App config
FREE_TIER_CAP=5
CORS_ORIGINS=*    # comma-separated in prod, e.g. https://yourapp.com
