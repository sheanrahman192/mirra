# Supabase — Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret   # Settings > API > JWT Secret (HS256)

# External APIs
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# App config
FREE_TIER_CAP=5
CORS_ORIGINS=*    # comma-separated in prod, e.g. https://yourapp.com
