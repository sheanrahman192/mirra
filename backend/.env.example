# Supabase — Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret   # Settings > API > JWT Secret (HS256)

# External APIs
OPENAI_API_KEY=sk-...

# Open model chat for /reflect through Hugging Face Inference Providers
OPEN_MODEL_API_KEY=hf_...
OPEN_MODEL_BASE_URL=https://router.huggingface.co/v1
OPEN_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-1M:fastest
OPEN_MODEL_MAX_TOKENS=350
OPEN_MODEL_TEMPERATURE=0.7

# Optional legacy fallback for debrief generation and reflection
ANTHROPIC_API_KEY=sk-ant-...

# App config
FREE_TIER_CAP=5
CORS_ORIGINS=*    # comma-separated in prod, e.g. https://yourapp.com
