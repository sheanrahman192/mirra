# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# GitHub MCP — generate at: github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=

# Supabase MCP — find at: supabase.com → your project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
